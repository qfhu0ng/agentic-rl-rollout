{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/bin/bash -lc \"sed -n '1000,1070p' src/flask/cli.py\"","aggregated_output":"@with_appcontext\ndef routes_command(sort: str, all_methods: bool) -> None:\n    \"\"\"Show all registered routes with endpoints and methods.\"\"\"\n\n    rules = list(current_app.url_map.iter_rules())\n    if not rules:\n        click.echo(\"No routes were registered.\")\n        return\n\n    ignored_methods = set(() if all_methods else (\"HEAD\", \"OPTIONS\"))\n\n    if sort in (\"endpoint\", \"rule\"):\n        rules = sorted(rules, key=attrgetter(sort))\n    elif sort == \"methods\":\n        rules = sorted(rules, key=lambda rule: sorted(rule.methods))  # type: ignore\n\n    rule_methods = [\n        \", \".join(sorted(rule.methods - ignored_methods))  # type: ignore\n        for rule in rules\n    ]\n\n    def _domain_for_rule(rule: t.Any) -> str:\n        host = getattr(rule, \"host\", None)\n        if host:\n            return host\n\n        subdomain = getattr(rule, \"subdomain\", None) or \"\"\n        server_name = current_app.config.get(\"SERVER_NAME\")\n\n        if not subdomain and not server_name:\n            return \"\"\n\n        if server_name:\n            return f\"{subdomain + '.' if subdomain else ''}{server_name}\"\n\n        return subdomain\n\n    rule_domains = [_domain_for_rule(rule) for rule in rules]\n    display_domain = any(domain for domain in rule_domains)\n\n    headers = (\"Endpoint\", \"Methods\", \"Rule\")\n\n    if display_domain:\n        headers = (\"Domain\",) + headers\n\n    widths = (\n        max(len(rule.endpoint) for rule in rules),\n        max(len(methods) for methods in rule_methods),\n        max(len(rule.rule) for rule in rules),\n    )\n\n    if display_domain:\n        widths = (max(len(domain) for domain in rule_domains),) + widths\n\n    widths = [max(len(h), w) for h, w in zip(headers, widths)]\n\n    if display_domain:\n        row = \"{{0:<{0}}}  {{1:<{1}}}  {{2:<{2}}}  {{3:<{3}}}\".format(*widths)\n    else:\n        row = \"{{0:<{0}}}  {{1:<{1}}}  {{2:<{2}}}\".format(*widths)\n\n    click.echo(row.format(*headers).strip())\n    click.echo(row.format(*(\"-\" * width for width in widths)))\n\n    for rule, methods, domain in zip(rules, rule_methods, rule_domains):\n        if display_domain:\n            click.echo(row.format(domain, rule.endpoint, methods, rule.rule).rstrip())\n        else:\n            click.echo(row.format(rule.endpoint, methods, rule.rule).rstrip())\n\n\n","exit_code":0,"status":"completed"}}
